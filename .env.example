"""Application backend configuration template."""

# Database
DATABASE_URL=postgresql+asyncpg://kembang:kembang@localhost:5432/kembang_db

# Redis (Optional - for rate limiting)
# Get free Redis from https://upstash.com
# Format: redis://default:password@host:port
REDIS_URL=

# Security
# IMPORTANT: Generate secure JWT secret with:
# python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET=

# LLM Providers (LiteLLM auto-detects these)
OPENAI_API_KEY=sk-proj-youropenaikey
GROQ_API_KEY=gsk_yourgroqkey
# ANTHROPIC_API_KEY=sk-ant-youranthropic

# Models
DEFAULT_LLM_MODEL=groq/llama-3.1-8b-instant
FALLBACK_LLM_MODEL=groq/llama-3.1-8b-instant
EMBEDDING_MODEL=text-embedding-3-small

# RAG configuration
CHUNK_SIZE=400
CHUNK_OVERLAP=80
MAX_CONTEXT_TOKENS=1500

# Backend specific
APP_ENV=production
DEBUG=False
CORS_ORIGINS=["https://kembang-console.vercel.app","https://kembang-tenant.vercel.app","https://kembang-widget.vercel.app"]
